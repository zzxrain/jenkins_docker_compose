# Copy to .env and change every secret before starting the stack.
TZ=Asia/Shanghai
JENKINS_URL=https://apps.localmac.net:8444/
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=change-me-please

# Public key paired with ./secrets/jenkins_agent_key.
# Generate with: ssh-keygen -t ed25519 -f secrets/jenkins_agent_key -N '' -C jenkins-agent
JENKINS_AGENT_SSH_PUBKEY=ssh-ed25519 REPLACE_WITH_PUBLIC_KEY jenkins-agent
